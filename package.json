{
  "name": "soma-ai",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:web": "turbo run dev --filter=@soma-ai/web",
    "dev:api": "turbo run dev --filter=@soma-ai/api",
    "db:seed": "turbo run db:seed",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:api": "playwright test api-crud",
    "test:e2e": "playwright test auth admin-panel company-panel",
    "test:mobile": "playwright test --project=mobile"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.10",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4"
}
