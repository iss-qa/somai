{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "passThroughEnv": [
        "META_APP_ID",
        "META_APP_SECRET",
        "META_REDIRECT_URI",
        "ENCRYPTION_KEY",
        "MONGO_PRDUSER",
        "MONGO_PRDPASS",
        "VITE_FACEBOOK_APP_ID"
      ]
    },
    "db:seed": {
      "cache": false
    }
  }
}
